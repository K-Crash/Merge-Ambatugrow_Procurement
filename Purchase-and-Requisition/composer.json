{
    "name": "ambatugrow/erp",
    "type": "project",
    "description": "AmbatuGrow ERP - PR & PO Approval Module",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/",
            "Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
